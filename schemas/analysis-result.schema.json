{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aprice.dev/schemas/analysis-result.schema.json",
  "title": "APrIce AnalysisResult",
  "description": "분석 엔진과 CLI, 리포트가 공유하는 v1 분석 결과 계약",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generatedAt",
    "repo",
    "budget",
    "traffic",
    "summary",
    "detections",
    "skipped"
  ],
  "properties": {
    "version": {
      "const": "1",
      "description": "정수 문자열 형식의 스키마 버전"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "분석 결과 생성 시각(UTC)"
    },
    "repo": {
      "$ref": "#/$defs/repo"
    },
    "budget": {
      "$ref": "#/$defs/budget"
    },
    "traffic": {
      "$ref": "#/$defs/traffic"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "detections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/detection"
      },
      "default": []
    },
    "skipped": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skipped"
      },
      "default": []
    }
  },
  "$defs": {
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?![A-Za-z]:[\\\\/])(?![\\\\/]).+",
      "description": "레포 루트 기준 상대 경로"
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "baseRef", "headRef"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[^/\\s]+/[^/\\s]+$",
          "description": "owner/repo 형식의 레포 이름"
        },
        "baseRef": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "diff 기준 ref. 전체 스캔은 null"
        },
        "headRef": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "분석 대상 ref. 로컬 실행에서는 null 가능"
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["monthlyUsd", "currency"],
      "properties": {
        "monthlyUsd": {
          "type": "number",
          "minimum": 0,
          "description": "사용자가 설정한 월 예산(USD)"
        },
        "currency": {
          "const": "USD",
          "description": "v1 계산 기준 통화"
        }
      }
    },
    "traffic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dau", "requestsPerUserPerDay"],
      "properties": {
        "dau": {
          "type": "number",
          "minimum": 0,
          "description": "일간 활성 사용자 수 가정"
        },
        "requestsPerUserPerDay": {
          "type": "number",
          "minimum": 0,
          "description": "사용자 한 명의 일간 요청 수 가정"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "totalMonthlyUsd",
        "deltaMonthlyUsd",
        "verdict",
        "detectionCount"
      ],
      "properties": {
        "totalMonthlyUsd": {
          "type": "number",
          "minimum": 0,
          "multipleOf": 0.01,
          "description": "가격을 계산할 수 있는 탐지 결과의 월 예상 비용 합계"
        },
        "deltaMonthlyUsd": {
          "type": ["number", "null"],
          "minimum": 0,
          "multipleOf": 0.01,
          "description": "diff 모드에서 이번 변경으로 증가한 월 예상 비용"
        },
        "verdict": {
          "enum": ["pass", "warn", "fail"],
          "description": "예산 게이트 판정"
        },
        "detectionCount": {
          "type": "integer",
          "minimum": 0,
          "description": "detections 배열과 일치해야 하는 탐지 건수"
        }
      }
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "provider",
        "product",
        "file",
        "line",
        "snippet",
        "multiplier",
        "multiplierReason",
        "estimatedCallsPerMonth",
        "estimatedMonthlyUsd",
        "unsupportedReason",
        "confidence",
        "isNew"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^d[1-9][0-9]*$",
          "description": "한 결과 안에서 고유한 탐지 ID"
        },
        "provider": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "가격 DB 파일명과 일치하는 소문자 provider 키"
        },
        "product": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "정적으로 판별한 상품 ID. 알 수 없으면 null"
        },
        "file": {
          "$ref": "#/$defs/relativePath"
        },
        "line": {
          "type": "integer",
          "minimum": 1,
          "description": "1부터 시작하는 call-site 줄 번호"
        },
        "snippet": {
          "type": "string",
          "minLength": 1,
          "description": "인자값과 비밀값을 제거한 호출부 축약 문자열"
        },
        "multiplier": {
          "type": "number",
          "minimum": 1,
          "description": "요청 한 번에 call-site가 실행될 것으로 추정한 횟수"
        },
        "multiplierReason": {
          "type": "string",
          "minLength": 1,
          "description": "multiplier의 근거를 설명하는 한글 문자열"
        },
        "estimatedCallsPerMonth": {
          "type": "number",
          "minimum": 0,
          "description": "트래픽과 multiplier를 반영한 월 예상 호출 수"
        },
        "estimatedMonthlyUsd": {
          "type": ["number", "null"],
          "minimum": 0,
          "multipleOf": 0.01,
          "description": "해당 call-site의 월 예상 비용"
        },
        "unsupportedReason": {
          "type": ["string", "null"],
          "minLength": 1,
          "description": "비용을 계산하지 못한 이유"
        },
        "confidence": {
          "enum": ["high", "medium", "low"],
          "description": "추정 결과의 신뢰도 등급"
        },
        "isNew": {
          "type": "boolean",
          "description": "diff 모드에서 이번 변경으로 추가된 호출인지 여부"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "estimatedMonthlyUsd": {
                "type": "null"
              }
            },
            "required": ["estimatedMonthlyUsd"]
          },
          "then": {
            "properties": {
              "unsupportedReason": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "else": {
            "properties": {
              "unsupportedReason": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "multiplier": {
                "const": 1
              }
            },
            "required": ["multiplier"]
          },
          "then": {
            "properties": {
              "multiplierReason": {
                "const": "단일 호출"
              }
            }
          }
        }
      ]
    },
    "skipped": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file", "reason"],
      "properties": {
        "file": {
          "$ref": "#/$defs/relativePath"
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "description": "분석을 건너뛴 기계 판독용 사유 코드"
        }
      }
    }
  }
}
